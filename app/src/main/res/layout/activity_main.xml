<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Employee NFC App"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#111827" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Передай этот ID администратору для регистрации"
        android:textSize="14sp"
        android:textColor="#374151" />

    <TextView
        android:id="@+id/tvEmployeeCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:padding="16dp"
        android:text="----"
        android:textColor="#111827"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.12" />

    <Button
        android:id="@+id/btnCopy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Скопировать ID"
        android:textAllCaps="false" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Важно: если удалить приложение — ID изменится (сгенерируется заново)."
        android:textSize="12sp"
        android:textColor="#6B7280" />

</LinearLayout>
