<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1220"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="677dp"
        android:layout_gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center_horizontal"
            android:text="Пропуск співробітника (NFC)"
            android:textColor="#EAF0FF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="match_parent"
            android:layout_height="37dp"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"
            android:text="Для реєстрації в системі - передайте цей код адміністратору."
            android:textColor="#9AA8C7"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/nfcDisabledBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#331A0F"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="NFC вимкнено"
                android:textColor="#FFD166"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_horizontal"
                android:text="Для роботи застосунку увімкніть NFC у налаштуваннях телефону."
                android:textColor="#E5E7EB"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnOpenNfcSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:text="Відкрити налаштування"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="149dp"
            android:layout_marginTop="18dp"
            android:background="#0F1A33"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:letterSpacing="0.12"
                android:text="КОД СПІВРОБІТНИКА"
                android:textColor="#9AA8C7"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmployeeCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="#111827"
                android:gravity="center"
                android:letterSpacing="0.14"
                android:padding="18dp"
                android:text="----"
                android:textColor="#EAF0FF"
                android:textSize="34sp"
                android:textStyle="bold" />


        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:gravity="center_horizontal"
            android:letterSpacing="0.12"
            android:text="Для авторизації піднесіть телефон до терміналу."
            android:textColor="#9AA8C7"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCopy"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Скопіювати код"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="178dp"
            android:layout_marginTop="10dp"
            android:gravity="center_horizontal"
            android:text="Важливо: якщо видалити застосунок, код може змінитися (згенерується знову)."
            android:textColor="#6F7FA6"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="69dp"
            android:layout_gravity="bottom"
            android:alpha="0.85"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="4dp"
            android:text="StelSuy Employee NFC"
            android:textColor="#6F7FA6"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>